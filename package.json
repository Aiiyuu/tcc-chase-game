  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "gulp",
    "dev": "gulp watch",
    "clean": "gulp clean",
    "deploy": "npm run build && gh-pages -d dist",
