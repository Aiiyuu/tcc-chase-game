  "description": "A web game about a coach on a bicycle escaping TCC employees across Ukraine. Inspired by a legendary frontend coach from MATE Academy.",
  "homepage": "https://github.com/Aiiyuu/tcc-chase-game#readme",
  "bugs": {
    "url": "https://github.com/Aiiyuu/tcc-chase-game/issues"
