    "del": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "gh-pages": "^6.3.0",
    "gulp": "^5.0.1",
    "gulp-sass": "^6.0.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-typescript": "^6.0.0-alpha.1",
    "htmlhint": "^1.6.3",
    "prettier": "^3.6.2",
    "sass": "^1.92.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^15.0.1",
